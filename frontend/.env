# ==============================================================================
# SMART BHARAT AI - COMPLETE ENVIRONMENT CONFIGURATION
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. CORE APPLICATION & DATABASE
# ------------------------------------------------------------------------------
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Secret Key used to sign & verify JWT Access & Refresh Tokens for session cookies
JWT_SECRET=smart-bharat-ai-secure-jwt-secret-key-2026-production

# Local SQLite Database Path
DATABASE_PATH=data/smart_bharat_db.json

# ------------------------------------------------------------------------------
# 2. GOOGLE OAUTH 2.0 CREDENTIALS
# (Obtain from https://console.cloud.google.com -> APIs & Services -> Credentials)
# Leave blank to use Dev Mode Instant Google Account Chooser simulation
# ------------------------------------------------------------------------------
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ------------------------------------------------------------------------------
# 3. SMS GATEWAY CREDENTIALS (TWILIO)
# (Obtain from https://www.twilio.com/console)
# Leave blank to use Dev Mode Screen & Console OTP code display
# ------------------------------------------------------------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ------------------------------------------------------------------------------
# 4. AI & LLM PROVIDER API KEYS (OPTIONAL)
# (For connecting live AI models to the Assistant)
# ------------------------------------------------------------------------------
GROQ_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=
